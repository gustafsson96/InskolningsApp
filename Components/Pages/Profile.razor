@page "/profil"
@attribute [Authorize]

@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Authorization
@using OnboardingApp.Models
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<h1>Profile & Settings</h1>

@if (isLoading)
{
    <p>Laddar...</p>
}
else if (appUser is not null)
{
    <div>
        <p><strong>Full Name:</strong> @fullName</p>
        <p><strong>Email:</strong> @appUser.Email</p>
        <p><strong>Role:</strong> @role</p>
        <p><strong>Start Date:</strong> @startDate</p>
    </div>
}

<button @onclick="GoBack">← Back</button>

@code {
    private ApplicationUser? appUser;
    private string fullName = "";
    private string role = "";
    private string startDate = "";
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
            return;

        appUser = await UserManager.GetUserAsync(user);

        if (appUser is not null)
        {
            fullName = $"{appUser.FirstName} {appUser.LastName}".Trim();

            var roles = await UserManager.GetRolesAsync(appUser);
            role = roles.FirstOrDefault() ?? "User";

            startDate = appUser.Startdate?.ToString("yyyy-MM-dd") ?? "-";
        }

        isLoading = false;
    }

    private void GoBack()
    {
        Nav.NavigateTo("/dashboard");
    }
}