@page "/profil"
@attribute [Authorize]

@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Authorization
@using OnboardingApp.Models
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<div class="profile-page">

    <button class="back-button" @onclick="GoBack">← Översikt</button>

    <h1>Profil & Inställningar</h1>

    @if (isLoading)
    {
        <p>Laddar...</p>
    }
    else if (appUser is not null)
    {
        <div class="profile-card">
        <h2>Personlig information</h2>

        <div class="info-card">
            <i class="fa-regular fa-user info-icon"></i>
            <div class="info-text">
                <p class="info-label">Namn</p>
                <p class="info-value">@fullName</p>
            </div>
        </div>

        <div class="info-card">
            <i class="fa-regular fa-envelope info-icon"></i>
            <div class="info-text">
                <p class="info-label">E-post</p>
                <p class="info-value">@appUser.Email</p>
            </div>
        </div>

        <div class="info-card">
            <i class="fa-regular fa-calendar info-icon"></i>
            <div class="info-text">
                <p class="info-label">Startdatum</p>
                <p class="info-value">@startDate</p>
            </div>
        </div>
        </div>
    }

    <div class="profile-card password-card">
        <div class="password-card-header">
            <i class="fa-solid fa-lock info-icon"></i>
            <h2>Ändra lösenord</h2>
        </div>

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <p class="password-message success">@successMessage</p>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <p class="password-message error">@errorMessage</p>
        }

        <div class="form-group">
            <label>Nuvarande lösenord</label>
            <input type="password" placeholder="Nuvarande lösenord" @bind="currentPassword" />
        </div>

        <div class="form-group">
            <label>Nytt lösenord</label>
            <input type="password" placeholder="Nytt lösenord" @bind="newPassword" />
            <small>Lösenordet måste vara minst 8 tecken</small>
        </div>

        <div class="form-group">
            <label>Bekräfta nytt lösenord</label>
            <input type="password" placeholder="Bekräfta nytt lösenord" @bind="confirmPassword" />
        </div>

        <button type="button" class="password-button" @onclick="ChangePassword">
            Byt lösenord
        </button>
    </div>
</div>

@code {
    private ApplicationUser? appUser;
    private string fullName = "";
    private string role = "";
    private string startDate = "";
    private bool isLoading = true;

    private string currentPassword = "";
    private string newPassword = "";
    private string confirmPassword = "";

    private string successMessage = "";
    private string errorMessage = "";
    
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
            return;

        appUser = await UserManager.GetUserAsync(user);

        if (appUser is not null)
        {
            fullName = $"{appUser.FirstName} {appUser.LastName}".Trim();

            var roles = await UserManager.GetRolesAsync(appUser);
            role = roles.FirstOrDefault() ?? "User";

            startDate = appUser.Startdate?.ToString("yyyy-MM-dd") ?? "-";
        }

        isLoading = false;
    }

    // Change password and show feedback messages
    private async Task ChangePassword()
    {
        successMessage = "";
        errorMessage = "";

        if (appUser is null)
        {
            errorMessage = "Användaren hittades inte.";
            return;
        }

        if (string.IsNullOrWhiteSpace(currentPassword) ||
            string.IsNullOrWhiteSpace(newPassword) ||
            string.IsNullOrWhiteSpace(confirmPassword))
        {
            errorMessage = "Alla fält måste fyllas i.";
            return;
        }

        if (newPassword != confirmPassword)
        {
            errorMessage = "Lösenorden matchar inte.";
            return;
        }

        var result = await UserManager.ChangePasswordAsync(
            appUser,
            currentPassword,
            newPassword
        );

        if (result.Succeeded)
        {
            successMessage = "Lösenordet har uppdaterats.";

            currentPassword = "";
            newPassword = "";
            confirmPassword = "";
        }
        else
        {
            errorMessage = string.Join(" ", result.Errors.Select(e => e.Description));
        }
    }

    private void GoBack()
    {
        Nav.NavigateTo("/dashboard");
    }
}