@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager Nav
@implements IDisposable

<div class="admin-sidebar">
    <div class="admin-sidebar-top">
        <div class="admin-header">
        <!-- Title -->
            <h2>Adminpanel</h2>
            <p>Introduktionshantering</p>
        </div>

        <!-- Admin links -->
        <nav class="admin-nav">
            <a href="/admin" class="admin-link @(IsActive("/admin") ? "active" : "")">
                <span class="admin-icon">▣</span>
                <span>Översikt</span>
            </a>
            <a href="/admin/moduler" class="admin-link @(IsActive("/admin/moduler") ? "active" : "")">
                <span class="admin-icon">≣</span>
                <span>Moduler & innehåll</span>
            </a>
            <a href="/admin/anvandare" class="admin-link @(IsActive("/admin/anvandare") ? "active" : "")">
                <span class="admin-icon">◉</span>
                <span>Användarhantering</span>
            </a>
            <a href="/admin/quiz" class="admin-link @(IsActive("/admin/quiz") ? "active" : "")">
                <span class="admin-icon">?</span>
                <span>Quiz</span>
            </a>
        </nav>
    </div>

    <!-- Actions -->
    <div class="admin-sidebar-bottom">
        <button class="admin-btn back-btn" @onclick="GoBack">
            ← Avsluta admin
        </button>
        <button class="admin-btn logout-btn">
            Logga ut
        </button>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }

    private bool IsActive(string route)
    {
        var currentUri = Nav.ToBaseRelativePath(Nav.Uri)
            .Split('?')[0]
            .Trim('/');

        var targetRoute = route.Trim('/');

        if (targetRoute == "admin")
        {
            return currentUri.Equals("admin", StringComparison.OrdinalIgnoreCase);
        }

        return currentUri.Equals(targetRoute, StringComparison.OrdinalIgnoreCase)
            || currentUri.StartsWith(targetRoute + "/", StringComparison.OrdinalIgnoreCase);
    }

    private void GoBack()
    {
        Nav.NavigateTo("/dashboard");
    }
}