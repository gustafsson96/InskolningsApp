@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager Nav


<div class="admin-sidebar">
    <div class="admin-sidebar-top">
        <div class="admin-header">
        <!-- Title -->
            <h2>Adminpanel</h2>
            <p>Introduktionshantering</p>
        </div>

        <!-- Admin links -->
        <nav class="admin-nav">
            <NavLink href="/admin"
                     class="admin-link"
                     ActiveClass="active"
                     Match="NavLinkMatch.All">
                <span class="admin-icon">▣</span>
                <span>Översikt</span>
            </NavLink>

            <NavLink href="/admin/moduler"
                     class="admin-link"
                     ActiveClass="active">
                <span class="admin-icon">≣</span>
                <span>Moduler & innehåll</span>
            </NavLink>

            <NavLink href="/admin/anvandare"
                     class="admin-link"
                     ActiveClass="active">
                <span class="admin-icon">◉</span>
                <span>Användarhantering</span>
            </NavLink>

            <NavLink href="/admin/quiz"
                     class="admin-link"
                     ActiveClass="active">
                <span class="admin-icon">?</span>
                <span>Quiz</span>
            </NavLink>
        </nav>
    </div>

    <!-- Actions -->
    <div class="admin-sidebar-bottom">
        <button class="admin-btn back-btn" @onclick="GoBack">
            ← Avsluta admin
        </button>
        <button class="admin-btn logout-btn">
            Logga ut
        </button>
    </div>
</div>

@code {
    private void GoBack()
    {
        Nav.NavigateTo("/dashboard");
    }
}