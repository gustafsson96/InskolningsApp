@* Component showing module overview cards (used in Dashboard) *@
<div class="module-overview">
    <div class="overview-card">
        <p>Antal moduler</p>
        <h2>@TotalModules</h2>
    </div>

    <div class="overview-card">
        <p>Slutförda</p>
        <h2 class="completed">@CompletedModules</h2>
    </div>

    <div class="overview-card">
        <p>Återstående</p>
        <h2 class="remaining">@RemainingModules</h2>
    </div>
</div>

@code {
    // Total number of modules
    [Parameter] public int TotalModules { get; set; }
    // Number of modules completed by the user
    [Parameter] public int CompletedModules { get; set; }
    // Number of modules the user has left to complete
    [Parameter] public int RemainingModules { get; set; }
}