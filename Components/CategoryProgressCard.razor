<div class="category-progress-card">
    <div class="category-progress-header">
        <h3>@Category</h3>
    </div>

    @if (!string.IsNullOrWhiteSpace(Description))
    {
        <p class="category-progress-description">@Description</p>
    }

    <div class="category-progress-footer">
        <span class="category-progress-label">Framsteg</span>
        <span class="category-progress-count">@Completed/@Total</span>
    </div>

    <div class="category-progress-bar-container">
        <div class="category-progress-bar-fill" style="width: @(Percentage)%"></div>
    </div>
</div>

@code {
    [Parameter] public string Category { get; set; } = string.Empty;
    [Parameter] public string? Description { get; set; }
    [Parameter] public int Total { get; set; }
    [Parameter] public int Completed { get; set; }

    private int Percentage => Total == 0 ? 0 : (Completed * 100) / Total;
}